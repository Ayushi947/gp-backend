# These are some examples of commonly ignored file patterns.
# You should customize this list as applicable to your project.
# Learn more about .gitignore:
#     https://www.atlassian.com/git/tutorials/saving-changes/gitignore

# Node artifact files
node_modules/
dist/

# Compiled Java class files
*.class

# Compiled Python bytecode
*.py[cod]

# Log files
*.log

# Package files
*.jar
# BUT keep gradle wrapper jar (required for CI/CD)
!gradle/wrapper/gradle-wrapper.jar

# Maven
target/
dist/
.gradle/

# Gradle
.gradle/
.gradle/8.13/executionHistory/
.gradle/8.13/fileHashes/
.gradle/buildOutputCleanup/
# Note: gradle/wrapper/ is NOT ignored - required for GitHub Actions
build/

# Misc
.get/

# JetBrains IDE
.idea/

# Unit test reports
TEST*.xml

# Generated by MacOS
.DS_Store

# Generated by Windows
Thumbs.db

# Applications
*.app
*.exe
*.war

# Large media files
*.mp4
*.tiff
*.avi
*.flv
*.mov
*.wmvdocker-compose.yml

# Spring Boot local configuration files
src/main/resources/application-local.properties
src/main/resources/application-local.yml
src/main/resources/application-local.yaml
**/application-local*.properties
**/application-local*.yml
**/application-local*.yaml

# Environment files
.env
.env.local
.env.*.local
*.env

# Local database files
*.db
*.sqlite
*.h2.db

# Log directories
logs/
log/

# IDE generated files
bin/
out/
*.iml
*.ipr
*.iws

# Local credentials and sensitive files
**/credentials.json
**/secrets.properties
**/*-secret.properties

# Backup and temporary files
*.bak
*.tmp
*.swp
*~

# Disabled test files
*.disabled

# Test coverage and summary documentation
**/TEST_COVERAGE*.md
**/COVERAGE*.md
**/WORK_COMPLETED*.md
**/CODE_OPTIMIZATION*.md
**/REFACTORING*.md
**/FINAL_SUMMARY.md
**/API_DOCUMENTATION.md
**/FRONTEND_INTEGRATION*.md
**/OPENAPI*.md
**/QUICK*.md
**/OPTIMIZATION*.md
**/TESTING*.md

# Keep docs/ folder documentation
!docs/**/*.md
!README.md
!HELP.md
!INTELLIJ_SETUP.md
!PROFILES.md
!BATCH_SCHEDULER_ARCHITECTURE.md
!.bitbucket/**/*.md
data/

# BTC Mock Server SFTP data
modules/btc-mock-server/sftp-root/
