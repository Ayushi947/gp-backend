# Backend Docker Environment Variables
# Copy this file to /home/ubuntu/gp-backend.env on the server
# Use Spring Boot's native property names (underscore format)

# Backend Image (from ECR or local build)
BACKEND_IMAGE=glidingpath-backend:latest

# Database (RDS) - Spring Boot native property names
SPRING_DATASOURCE_URL=jdbc:postgresql://your-rds-host:5432/glidingpath_db
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your-db-password
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver

# Flyway (same as database)
SPRING_FLYWAY_URL=jdbc:postgresql://your-rds-host:5432/glidingpath_db
SPRING_FLYWAY_USER=postgres
SPRING_FLYWAY_PASSWORD=your-db-password
SPRING_FLYWAY_DRIVER_CLASS_NAME=org.postgresql.Driver

# Redis (ElastiCache with TLS) - Spring Boot native property names
SPRING_DATA_REDIS_HOST=your-elasticache-host.cache.amazonaws.com
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=your-redis-password
SPRING_DATA_REDIS_SSL_ENABLED=true

# Mail (Brevo SMTP)
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=your-brevo-username
MAIL_PASSWORD=your-brevo-password
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
MAIL_SMTP_STARTTLS_REQUIRED=true
EMAIL_FROM=info@glidingpath.co

# Cookie Configuration (for cross-origin authentication)
# For production with separate frontend/backend domains:
APP_COOKIE_SECURE=true
APP_COOKIE_SAME_SITE=None
APP_COOKIE_DOMAIN=.glidingpath.co

# JWT Configuration
JWT_SECRET=your-very-long-secure-random-string-for-hmac-512
JWT_ACCESS_TOKEN_EXPIRATION=900000
JWT_REFRESH_TOKEN_EXPIRATION=604800000
